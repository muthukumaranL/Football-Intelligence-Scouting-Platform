# =============================================================================
# Football Intelligence Scouting Platform — example environment variables
# Copy this file to ".env" and fill in values to enable optional live data.
# The app runs fully WITHOUT any of these (it falls back to sample data).
# =============================================================================

# --- Optional: Kaggle API (to auto-download a real FIFA player dataset) ------
# Create a token at https://www.kaggle.com/settings -> "Create New Token".
KAGGLE_USERNAME=
KAGGLE_KEY=

# --- Optional: a generic football data API (e.g. football-data.org) ----------
# Free tier key from https://www.football-data.org/client/register
FOOTBALL_DATA_API_KEY=

# --- Optional: RapidAPI / API-FOOTBALL style key -----------------------------
API_FOOTBALL_KEY=

# --- App behavior ------------------------------------------------------------
# Set to 1 to force regeneration of the synthetic sample dataset on startup.
FORCE_REGENERATE_SAMPLE=0
